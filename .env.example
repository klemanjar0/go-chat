ENV=DEVELOPMENT
HTTP_PORT=8080

# Postgres
DB_HOST=localhost
DB_PORT=5432
DB_USER=chat-db-admin
DB_PASSWORD=chat-db-admin-password
DB_NAME=chat-db
DB_SSL_MODE=disable
DB_MAX_CONNS=10

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Auth
# JWT_SECRET is required when ENV=PRODUCTION; in dev a fallback is used.
JWT_SECRET=
JWT_ISSUER=go-chat
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
BCRYPT_COST=12
